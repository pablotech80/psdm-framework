{
  "version": 1,
  "profile": "framework",
  "requiredArtifacts": [
    "AGENTS.md",
    "ROADMAP.md",
    "TODO.md",
    "docs/INDEX.md",
    "docs/PROJECT_BRIEF.md",
    "docs/SPEC.md",
    "docs/BETA_RELEASE_NOTES.md",
    "docs/CONFIG_SCHEMA.md",
    "docs/AI_READINESS_AUDIT.md",
    "docs/ARCHITECTURE.md",
    "docs/CHANGE_GOVERNANCE.md",
    "docs/TASKS.md",
    "docs/TESTING.md",
    "docs/DEPLOYMENT.md",
    "docs/SECURITY.md",
    "docs/OPERATIONS.md",
    "ADRs"
  ],
  "extraRequiredArtifacts": [],
  "features": {
    "root": "docs/features",
    "requiredArtifacts": [
      "PROJECT_BRIEF.md",
      "SPEC.md",
      "ARCHITECTURE.md",
      "SECURITY.md",
      "TESTING.md"
    ]
  },
  "git": {
    "warnOnDirty": true
  },
  "ai": {
    "pii": {
      "allowedInPrompts": false,
      "redactionRequired": true
    },
    "cost": {
      "maxUsdPerRequest": null,
      "monthlyBudgetUsd": null
    },
    "latency": {
      "p95Ms": null
    },
    "tools": {
      "registryRequired": true,
      "humanApprovalForExternalActions": true
    },
    "evals": {
      "required": true
    },
    "security": {
      "promptInjectionTestsRequired": true
    }
  },
  "approval": {
    "maxReceiptAgeSeconds": 600,
    "requiredActions": [],
    "requiredLevels": [],
    "trustedApprovers": [
      {
        "id": "ptech-owner",
        "publicKeyPath": "governance/keys/ptech-owner-public.pem",
        "publicKeyFingerprint": "sha256:0b0ccfe3d85df230f8d63a2178137c05d7ae3cfd457a1a97d43af1270c50a0c5",
        "approvalModes": [
          "hardware-signature"
        ]
      }
    ]
  },
  "riskPaths": [
    {
      "pattern": "bin/**",
      "minimumLevel": "Level 2",
      "requiredArtifacts": ["docs/SPEC.md", "docs/TESTING.md"],
      "reason": "CLI entrypoint changes alter user-facing command behavior."
    },
    {
      "pattern": "src/commands/**",
      "minimumLevel": "Level 2",
      "requiredArtifacts": ["docs/SPEC.md", "docs/TESTING.md"],
      "reason": "Command changes alter PSDM behavior and automation output."
    },
    {
      "pattern": "src/validator/**",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Validator changes affect governance decisions and repository policy enforcement."
    },
    {
      "pattern": "src/lib/config.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Config loading changes affect policy interpretation."
    },
    {
      "pattern": "src/lib/args.mjs",
      "minimumLevel": "Level 2",
      "requiredArtifacts": ["docs/SPEC.md", "docs/TESTING.md"],
      "reason": "Argument parsing changes affect command behavior and automation usage."
    },
    {
      "pattern": "src/lib/audit.mjs",
      "minimumLevel": "Level 2",
      "requiredArtifacts": ["docs/SPEC.md", "docs/TESTING.md"],
      "reason": "Audit changes affect repository adoption previews."
    },
    {
      "pattern": "src/lib/classifier.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/TESTING.md"],
      "reason": "Classifier changes affect change-level decisions."
    },
    {
      "pattern": "src/lib/pr-checklist.mjs",
      "minimumLevel": "Level 2",
      "requiredArtifacts": ["docs/SPEC.md", "docs/TASKS.md", "docs/TESTING.md"],
      "reason": "PR checklist changes affect review workflow guidance."
    },
    {
      "pattern": "src/lib/risk-paths.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Risk path logic affects change-level classification."
    },
    {
      "pattern": "AGENTS.md",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Agent instruction changes can alter autonomous behavior, approval boundaries, and tool use."
    },
    {
      "pattern": "templates/AGENTS.md",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Generated agent instruction changes alter downstream autonomous behavior and approval boundaries."
    },
    {
      "pattern": "src/commands/approval.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Approval command changes can alter human-authority and commit enforcement boundaries."
    },
    {
      "pattern": "src/commands/hook.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Hook command changes can alter local Git enforcement boundaries."
    },
    {
      "pattern": "src/lib/*approval*.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Approval library changes can alter signature, trust, expiry, or replay decisions."
    },
    {
      "pattern": "src/lib/action-record.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Action record changes can alter the content bound to human approval."
    },
    {
      "pattern": "src/lib/git-hook.mjs",
      "minimumLevel": "Level 3",
      "requiredArtifacts": ["docs/SPEC.md", "docs/ARCHITECTURE.md", "docs/SECURITY.md", "docs/TESTING.md"],
      "reason": "Git hook changes can weaken or bypass local approval enforcement."
    },
    {
      "pattern": "templates/**",
      "minimumLevel": "Level 2",
      "requiredArtifacts": ["docs/SPEC.md", "docs/TESTING.md"],
      "reason": "Template changes affect newly initialized PSDM projects."
    },
    {
      "pattern": "tests/**",
      "minimumLevel": "Level 2",
      "requiredArtifacts": ["docs/TESTING.md"],
      "reason": "Fixture changes affect regression coverage."
    },
    {
      "pattern": ".github/workflows/**",
      "minimumLevel": "Level 4",
      "requiredArtifacts": ["docs/DEPLOYMENT.md", "docs/OPERATIONS.md", "docs/SECURITY.md"],
      "reason": "CI workflow changes can alter release, validation, and secret handling behavior."
    },
    {
      "pattern": "action.yml",
      "minimumLevel": "Level 4",
      "requiredArtifacts": ["docs/DEPLOYMENT.md", "docs/OPERATIONS.md", "docs/SECURITY.md"],
      "reason": "GitHub Action changes affect downstream repository automation."
    },
    {
      "pattern": "package.json",
      "minimumLevel": "Level 4",
      "requiredArtifacts": ["docs/DEPLOYMENT.md", "docs/OPERATIONS.md", "docs/TESTING.md"],
      "reason": "Package metadata changes affect distribution and install behavior."
    }
  ]
}
